{
	"name": "whatchar",
	"displayName": "whatchar",
	"description": "what character does it points at",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.46.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "whatchar.show",
				"title": "Show what character"
			}
		],
		"configuration": {
			"title": "whatchar",
			"properties": {
				"whatchar.showOnCursorMove": {
					"type": "boolean",
					"default": true,
					"description": "Show character info in the status bar whenever the cursor moves."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "yarn run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "yarn run compile",
		"test": "node ./out/test/runTest.js"
	},
	"dependencies": {
		"iconv-lite": "^0.6.3"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.0",
		"@types/node": "^13.11.0",
		"@types/vscode": "^1.46.0",
		"@vscode/test-electron": "^2.5.2",
		"mocha": "^10.0.0",
		"typescript": "^3.8.3"
	},
	"resolutions": {
		"serialize-javascript": "^7.0.5"
	}
}
